# Supabase project URL — local: http://127.0.0.1:54321, prod: https://<ref>.supabase.co
PUBLIC_SUPABASE_URL=

# Anon (publishable) key — safe to ship to the browser
PUBLIC_SUPABASE_ANON_KEY=

# Service-role key — server-only, never ship to the browser.
# Used in Phase 1b for service-role writes (e.g. songlink_cache).
SUPABASE_SERVICE_ROLE_KEY=

# Origin for magic-link redirect. Local dev: http://localhost:5173 ; prod: https://mixtapestory.com
PUBLIC_SITE_URL=
