# Supabase project URL — local: http://127.0.0.1:54321, prod: https://<ref>.supabase.co
PUBLIC_SUPABASE_URL=

# Anon (publishable) key — safe to ship to the browser
PUBLIC_SUPABASE_ANON_KEY=

# Service-role key — server-only, never ship to the browser.
# Used in Phase 1b for service-role writes (e.g. songlink_cache).
SUPABASE_SERVICE_ROLE_KEY=

# Origin for magic-link redirect. Local dev: http://localhost:5173 ; prod: https://mixtapestory.com
PUBLIC_SITE_URL=

# Apple Music API (MusicKit). Server-only. Phase 2 resolver.
# The .p8 file is generated once in Apple Developer Portal → Keys → MusicKit
# (you only get to download it one time). Real values live in .env.local
# (gitignored) and as Cloudflare Pages secrets in prod.
APPLE_MUSIC_KEY_ID=
APPLE_MUSIC_TEAM_ID=
# Full PEM contents including BEGIN/END lines, newlines preserved.
# In .env.local, write it as:
#   APPLE_MUSIC_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----
#   MIG...
#   -----END PRIVATE KEY-----"
APPLE_MUSIC_PRIVATE_KEY=

