# Dependencies
node_modules/

# Build output
.svelte-kit/
build/
.output/
.vercel/
.netlify/
.wrangler/

# Env — commit .env.example, ignore everything else
.env
.env.*
!.env.example

# Apple MusicKit private key (the .p8 file you download once from the
# developer portal). Never commit — it's a credential.
*.p8
AuthKey_*

# Wrangler local dev env file (for `wrangler pages dev`)
.dev.vars

# Logs
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# TypeScript incremental build info
*.tsbuildinfo

# Vite timestamp files
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# Test coverage
coverage/

# Playwright artifacts (HTML report, traces, videos, screenshots).
# Everything Playwright writes lives under testing/e2e/results — safe
# to rm -rf without touching any tests, fixtures, or page objects.
testing/e2e/results/
# The (stashed) demo POC writes its videos + ffmpeg composites here.
# Same as above: rm -rf is safe; only artifacts live in results/.
testing/e2e/demos/results/
# Playwright's internal browser-install cache (separate from results)
playwright/.cache/

# Supabase local stack
supabase/.branches/
supabase/.temp/

# Local caches
.cache/
.fastembed_cache/
test-results/
testing/results/

# Personal mockup: embeds Bryan's own mixtape stories with named
# references. Kept locally as a working artifact; not shipped in the
# public repo. Replace with seed-data-backed mockup if the coverflow
# concept ever needs to be a public design reference.
docs/mockups/coverflow-poc.html
